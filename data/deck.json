  "css": ".card {\n font-family: arial;\n font-size: 20px;\n text-align: center;\n color: black;\n background-color: white;\n}\n.replay-button svg {\n width: 40px;\n height: 40px;\n}\n.replay-button svg circle {\n fill: #279FF5;\n}\n.replay-button svg path {\n fill: white;\n}\n",
